# Normalize line endings for all text files
* text=auto eol=lf

# Treat Rust files as text
*.rs text

# Ensure Markdown files use LF
*.md text eol=lf

# Ensure shell scripts use LF
*.sh text eol=lf

# Prevent GitHub from misclassifying vendored code
vendor/** linguist-vendored=true

# Exclude generated files from language statistics
*.lock linguist-generated=true
